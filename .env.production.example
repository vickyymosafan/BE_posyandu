# Railway Production Environment Variables for Backend
# Copy this file to .env.production and fill in the values for local production testing

# ================================
# RAILWAY ENVIRONMENT DETECTION
# ================================
# These are automatically set by Railway - DO NOT MODIFY
RAILWAY_ENVIRONMENT=production
RAILWAY_PROJECT_ID=your-railway-project-id
RAILWAY_SERVICE_NAME=backend
RAILWAY_DEPLOYMENT_ID=auto-generated-by-railway
RAILWAY_REGION=ap-southeast1

# ================================
# SERVER CONFIGURATION
# ================================
NODE_ENV=production
PORT=5000

# ================================
# DATABASE CONFIGURATION
# ================================
# Railway MySQL Database Connection
# Railway automatically provides DATABASE_URL, but you can also use individual variables
DATABASE_URL=mysql://username:password@host:port/database_name

# Alternative individual database variables (if not using DATABASE_URL)
DB_HOST=your-railway-mysql-host
DB_USER=your-database-username
DB_PASSWORD=your-database-password
DB_NAME=posyandu_db
DB_PORT=3306

# Railway MySQL service variables (automatically provided by Railway)
MYSQL_URL=mysql://username:password@host:port/database_name
MYSQLHOST=your-railway-mysql-host
MYSQLUSER=your-database-username
MYSQLPASSWORD=your-database-password
MYSQLDATABASE=posyandu_db
MYSQLPORT=3306

# ================================
# SECURITY CONFIGURATION
# ================================
# JWT Secret for token signing (use Railway's secret generator)
JWT_SECRET=your-super-secure-jwt-secret-key-minimum-32-characters

# ================================
# RATE LIMITING CONFIGURATION
# ================================
# Rate limiting settings for production (15 minutes window)
RATE_LIMIT_WINDOW_MS=900000
# Higher limit for Railway production environment
RATE_LIMIT_MAX_REQUESTS=200

# ================================
# FILE UPLOAD CONFIGURATION
# ================================
# Railway uses ephemeral storage, so use /tmp for uploads
UPLOAD_PATH=/tmp/uploads
# Maximum file size in bytes (10MB)
MAX_FILE_SIZE=10485760

# ================================
# FRONTEND CONFIGURATION
# ================================
# Railway frontend URL for CORS configuration
RAILWAY_FRONTEND_URL=https://your-frontend-service.up.railway.app
FRONTEND_URL=https://your-frontend-service.up.railway.app

# ================================
# LOGGING AND MONITORING
# ================================
# Log level for production
LOG_LEVEL=info
# Enable detailed error logging
DETAILED_ERRORS=false

# ================================
# RAILWAY DEPLOYMENT NOTES
# ================================
# 1. Railway automatically sets RAILWAY_* environment variables
# 2. DATABASE_URL is automatically provided by Railway MySQL service
# 3. PORT is automatically set by Railway
# 4. Use Railway's secret generator for JWT_SECRET
# 5. UPLOAD_PATH should be /tmp/uploads for Railway ephemeral storage
# 6. CORS origins are automatically configured for Railway domains
# 7. Health check endpoint is available at /api/health
# 8. Ready check endpoint is available at /api/ready

# ================================
# REQUIRED RAILWAY VARIABLES
# ================================
# These variables MUST be set in Railway dashboard:
# - JWT_SECRET (generate secure random string)
# - DATABASE_URL (automatically provided by MySQL service)
# - RAILWAY_FRONTEND_URL (set to frontend service URL)

# ================================
# OPTIONAL RAILWAY VARIABLES
# ================================
# These variables can be customized in Railway dashboard:
# - RATE_LIMIT_WINDOW_MS (default: 900000)
# - RATE_LIMIT_MAX_REQUESTS (default: 200)
# - LOG_LEVEL (default: info)
# - MAX_FILE_SIZE (default: 10485760)